{
  "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",
  "plugins": ["./plugins/no-process-exit.grit"],
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "indentStyle": "space",
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    },
    "globals": ["Bun"]
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUndeclaredDependencies": "error",
        "noUndeclaredVariables": "error",
        "noUnusedVariables": "error",
        "noUnusedImports": "error"
      },
      "security": {}
    }
  },
  "files": {
    "includes": ["**", "!**/dist/", "!**/node_modules/", "!**/.idea/", "!**/.claude/"]
  }
}
